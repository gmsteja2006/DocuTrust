# ══════════════════════════════════════════
# DocuTrust — Environment Configuration
# ══════════════════════════════════════════
# This file configures the DocuTrust backend.
# Set your API keys below to enable LLM generation.
# Without API keys, the system runs in Local Extractive Mode (no LLM needed).

# ── LLM Provider ──
# Choose "google", "openai", or "mock"
LLM_PROVIDER=google

# ── Google Gemini (recommended — free tier available) ──
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── OpenAI (alternative) ──
# OPENAI_API_KEY=your-openai-key-here

# ── LLM Model ──
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── MongoDB ──
# Start MongoDB locally or use MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=docutrust

# ── Embedding Model (runs locally, no key needed) ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Reranker / CrossEncoder (runs locally, no key needed) ──
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RELEVANCE_THRESHOLD=0.5

# ── Retrieval Settings ──
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# ── Document Ingestion ──
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Web Search Fallback ──
WEB_SEARCH_MAX_RESULTS=3

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=True
